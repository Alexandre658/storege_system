# Storage Server
STORAGE_HOST=0.0.0.0
STORAGE_PORT=8091
STORAGE_DATA_DIR=./data
STORAGE_DATABASE_URL=sqlite://./data/storage.db
STORAGE_SIGNED_URL_SECRET=change-me-in-production
STORAGE_MAX_UPLOAD_SIZE=104857600
STORAGE_BASE_URL=http://localhost:8091
STORAGE_BACKUP_DIR=./backups
STORAGE_BACKUP_RETENTION_COUNT=10
STORAGE_BACKUP_AUTO_INTERVAL_HOURS=0
STORAGE_AUTO_CREATE_BUCKETS=true
STORAGE_DEFAULT_BUCKET_LOCATION=us-central1

# Firebase (aceita FIREBASE_* ou STORAGE_FIREBASE_*)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
